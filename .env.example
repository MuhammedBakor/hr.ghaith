# ════════════════════════════════════════════════════
# غيث ERP — متغيرات البيئة
# ════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL=mysql://root:password@localhost:3306/ghaith_erp
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=ghaith_erp

# ── Server ──
PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# ── Authentication ──
JWT_SECRET=your_jwt_secret_here_min_32_chars
SESSION_SECRET=your_session_secret_here_min_32_chars
COOKIE_DOMAIN=localhost

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@ghaith-erp.com

# ── WhatsApp (Optional) ──
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ── SMS (Optional) ──
SMS_API_URL=
SMS_API_KEY=

# ── File Storage ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Logging ──
LOG_LEVEL=info

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── Error Monitoring (Optional) ──
SENTRY_DSN=

# ── AI Features (Optional) ──
OPENAI_API_KEY=


# ═══ Workers & Automation ═══
APP_VERSION=1.0.0
AUTOMATION_WORKER_INTERVAL=60000
BUILD_NUMBER=1
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=
COMMIT_HASH=
ENABLE_AUTOMATION_WORKER=true
ENABLE_JOB_WORKER=true
ENABLE_SLA_CRON=true
ENABLE_SMART_NOTIFICATIONS=true
GMAIL_MCP_ENABLED=false
INTERNAL_API_KEY=
JOB_WORKER_BATCH_SIZE=10
JOB_WORKER_CONCURRENCY=5
JOB_WORKER_POLL_INTERVAL=5000
MCP_SERVER_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
SKIP_GOVERNANCE_CHECK=false
SLA_CRON_INTERVAL=3600000
SMTP_SECURE=true
VITE_APP_ID=ghaith-erp
VITE_APP_URL=http://localhost:3000
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Admin IP Whitelist — اختياري
# قائمة IPs المسموح لها بالوصول الإداري (فارغة = لا قيود)
# مثال: ADMIN_IP_WHITELIST=192.168.1.100,10.0.0.0.*
ADMIN_IP_WHITELIST=

# Security — CRITICAL
DEFAULT_PASSWORD=change_me_in_production

# مفتاح تشفير التوكنات — إلزامي في كل البيئات
# لتوليد قيمة آمنة: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ لا تستخدم نفس القيمة في بيئات مختلفة
# ⚠️ احتفظ بنسخة آمنة — فقدانه يعني فقدان جميع التوكنات المشفرة
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here_generate_with_command_above

# Redis — لتفعيل Redis Rate Limiting في الإنتاج الموزع (تقرير #15)
# REDIS_URL=redis://localhost:6379

# ═══ Database Pool (P2-2 Fix) ═══
DB_POOL_SIZE=20
DB_POOL_IDLE=10

# ═══ Docker Compose ═══
DB_PASSWORD=your_strong_db_password_here
DB_NAME=ghaith_erp
