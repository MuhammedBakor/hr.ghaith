# API URL (backend base URL)
# Development: leave empty to use localhost:8080 (see src/lib/api.ts)
# Production: set to your cloud domain, e.g. https://hr.door.sa/api/v1
VITE_API_URL=

# Public site URL (used to generate shareable job application links)
# Development: http://localhost:5173
# Production: set to your cloud domain, e.g. https://hr.door.sa
VITE_APP_URL="http://localhost:5173"
